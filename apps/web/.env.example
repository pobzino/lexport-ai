# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_your_publishable_key"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_your_secret_key"
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# OpenAI (GPT-5.4 for contract generation)
OPENAI_API_KEY="sk-..."
OPENAI_CONTRACT_GENERATION_MODEL="gpt-5.4"
OPENAI_CONTRACT_GENERATION_TIMEOUT_MS="120000"
OPENAI_CONTRACT_GENERATION_JOB_TIMEOUT_MS="600000"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."
STRIPE_PRO_ANNUAL_PRICE_ID="price_..."
STRIPE_TEAM_ANNUAL_PRICE_ID="price_..."
STRIPE_FIRST_MONTH_COUPON_ID="..."

# Email (Resend)
RESEND_API_KEY="re_..."
# Sender address - use onboarding@resend.dev for testing, then your verified domain
EMAIL_FROM="Lexport <noreply@yourdomain.com>"
# Where to send contact form submissions
SUPPORT_EMAIL="support@yourdomain.com"

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Sentry (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_ORG="your-org"
SENTRY_PROJECT="lexport-web"
SENTRY_AUTH_TOKEN="sntrys_..."

# App
NEXT_PUBLIC_APP_URL="https://lexportai.com"
CRON_SECRET="generate-a-long-random-secret"
