{
  "name": "lexport",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@lexport/web",
    "dev:mobile": "turbo dev --filter=@lexport/mobile",
    "build": "turbo build",
    "build:web": "turbo build --filter=@lexport/web",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.0.0"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "bun@1.1.0",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.88",
    "pdf-parse": "1.1.1"
  }
}
